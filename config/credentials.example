# Git User Accounts Configuration
# =================================
# Copy this file to ~/.ge/credentials to use it.
# install.sh does this automatically.
#
# Format: INI-style profiles
#
#   [profile_name]     - unique profile identifier
#   name               - git user.name
#   email              - git user.email
#   ssh_key            - path to SSH private key (~/ supported)
#
# Examples:
#
# [work]
# name = John Work
# email = john@company.com
# ssh_key = ~/.ssh/work_ed25519
#
# [personal]
# name = John Personal
# email = john@gmail.com
# ssh_key = ~/.ssh/personal_ed25519

# Add your accounts below:
