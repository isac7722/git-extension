#!/usr/bin/env bash
# ============================================================
# ge — Git Extension CLI (standalone executable)
# ============================================================
# This is the PATH-installed binary. It handles:
#   - ge init <shell>    → outputs shell integration code
#   - ge version         → prints version
#   - ge worktree <sub>  → worktree management
#   - ge <anything>      → git passthrough
#
# Commands that modify the current shell environment
# (ge user <alias>) are handled by the sourced shell function,
# not this binary.
# ============================================================

set -e

# ── Resolve GE_HOME (handles symlinks) ───────────────────────

_ge_resolve_home() {
  local source="${BASH_SOURCE[0]}"
  # Resolve symlinks
  while [[ -L "$source" ]]; do
    local dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    # Handle relative symlinks
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  local dir="$(cd -P "$(dirname "$source")" && pwd)"
  echo "$(cd "$dir/.." && pwd)"
}

export GE_HOME="${GE_HOME:-$(_ge_resolve_home)}"

# Source core for version
source "$GE_HOME/lib/_ge_core.sh"

# ── Shell/RC detection helpers ────────────────────────────────

_ge_detect_shell() {
  case "$(uname -s)" in
    Darwin*) echo "zsh" ;;
    Linux*)
      if [[ -n "$ZSH_VERSION" ]] || [[ "$SHELL" == */zsh ]]; then
        echo "zsh"
      else
        echo "bash"
      fi
      ;;
    *) echo "" ;;
  esac
}

_ge_detect_rc_file() {
  local shell_type="$1"
  case "$shell_type" in
    zsh)  echo "$HOME/.zshrc" ;;
    bash)
      if [[ "$(uname -s)" == "Darwin" ]]; then
        echo "$HOME/.bash_profile"
      else
        echo "$HOME/.bashrc"
      fi
      ;;
    *) echo "" ;;
  esac
}

# ── Legacy gituser migration ─────────────────────────────────

_ge_migrate_legacy() {
  local legacy_dir="$HOME/.config/gituser"
  local legacy_config="$legacy_dir/accounts"
  local legacy_profiles="$legacy_dir/profiles"
  local ge_config_dir="$HOME/.ge"
  local ge_config="$ge_config_dir/credentials"
  local ge_profiles="$ge_config_dir/profiles"
  local dry_run="${1:-false}"

  # Only run if legacy directory exists
  [[ -d "$legacy_dir" ]] || return 0

  echo ""
  echo "── Legacy gituser detected ─────────────────────"
  echo "  Migrating from ~/.config/gituser → ~/.ge"
  echo ""

  # a. Account migration
  if [[ -f "$legacy_config" ]]; then
    # Skip if credentials already has real data (not just the example template)
    local has_real_data=false
    if [[ -f "$ge_config" ]]; then
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        [[ "${line:0:1}" == "#" ]] && continue
        has_real_data=true
        break
      done < "$ge_config"
    fi

    if $has_real_data; then
      echo "  ⏭ Credentials already exist, skipping account migration"
    else
      local count=0 ini_output=""
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        [[ "${line:0:1}" == "#" ]] && continue

        local raw_aliases="${line%%:*}"
        local rest="${line#*:}"
        local name="${rest%%:*}"
        rest="${rest#*:}"
        local email="${rest%%:*}"
        local key_path="${rest#*:}"

        local profile="${raw_aliases%%,*}"
        profile="${profile// /}"

        [[ -n "$ini_output" ]] && ini_output="${ini_output}
"
        ini_output="${ini_output}[$profile]
name = $name
email = $email
ssh_key = $key_path"
        count=$((count + 1))
      done < "$legacy_config"

      if [[ $count -gt 0 ]]; then
        if $dry_run; then
          echo "  [dry-run] Would migrate $count account(s) to $ge_config"
        else
          mkdir -p "$ge_config_dir"
          printf '%s\n' "$ini_output" > "$ge_config"
          echo "  ✔ Migrated $count account(s) → $ge_config"
        fi
      fi
    fi
  fi

  # b. Profile copy
  if [[ -d "$legacy_profiles" ]]; then
    if $dry_run; then
      echo "  [dry-run] Would copy profiles to $ge_profiles"
    else
      mkdir -p "$ge_profiles"
      cp -n "$legacy_profiles"/* "$ge_profiles/" 2>/dev/null || true
      echo "  ✔ Profiles copied → $ge_profiles"
    fi
  fi

  # c. gitconfig marker conversion
  local gitconfig="$HOME/.gitconfig"
  if [[ -f "$gitconfig" ]] && grep -q "gituser" "$gitconfig" 2>/dev/null; then
    if $dry_run; then
      echo "  [dry-run] Would update gitconfig markers"
    else
      local tmp_gc
      tmp_gc="$(mktemp)"
      sed -e 's/# gituser:rule:/# ge:rule:/g' \
          -e 's|\.config/gituser/profiles/|.ge/profiles/|g' \
          "$gitconfig" > "$tmp_gc"
      mv "$tmp_gc" "$gitconfig"
      echo "  ✔ Updated gitconfig markers"
    fi
  fi

  # d. RC block cleanup
  local legacy_start="# >>> gituser >>>"
  local legacy_end="# <<< gituser <<<"
  for rc in "$HOME/.zshrc" "$HOME/.bashrc"; do
    if [[ -f "$rc" ]] && grep -q "$legacy_start" "$rc" 2>/dev/null; then
      if $dry_run; then
        echo "  [dry-run] Would remove gituser block from $rc"
      else
        local tmp_rc
        tmp_rc="$(mktemp)"
        awk -v start="$legacy_start" -v end="$legacy_end" '
          $0 ~ start { skip=1; next }
          $0 ~ end   { skip=0; next }
          !skip { print }
        ' "$rc" > "$tmp_rc"
        mv "$tmp_rc" "$rc"
        echo "  ✔ Removed gituser block from $rc"
      fi
    fi
  done

  # e. Backup legacy directory
  if $dry_run; then
    echo "  [dry-run] Would backup $legacy_dir"
  else
    local backup_name="${legacy_dir}.bak.$(date +%Y%m%d)"
    mv "$legacy_dir" "$backup_name"
    echo "  ✔ Backed up → $backup_name"
  fi

  # f. gituser command removal hint
  if command -v gituser &>/dev/null; then
    echo ""
    echo "  ⚠ Legacy 'gituser' command is still installed."
    echo "    To remove it, run:"
    echo "      npm uninstall -g gituser"
  fi

  echo ""
}

# ── ge setup ──────────────────────────────────────────────────

_ge_setup() {
  local dry_run=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  # Migrate legacy gituser data (silently skips if not found)
  _ge_migrate_legacy "$dry_run" || true

  local shell_type
  shell_type="$(_ge_detect_shell)"
  if [[ -z "$shell_type" ]]; then
    echo "Error: Could not detect shell type." >&2
    echo "Supported shells: zsh, bash" >&2
    return 1
  fi

  local rc_file
  rc_file="$(_ge_detect_rc_file "$shell_type")"
  if [[ -z "$rc_file" ]]; then
    echo "Error: Could not determine RC file." >&2
    return 1
  fi

  local marker_start="# >>> ge-cli >>>"
  local marker_end="# <<< ge-cli <<<"

  # Check if already configured
  if grep -q "$marker_start" "$rc_file" 2>/dev/null; then
    echo "✓ Shell integration is already configured in $rc_file"
    if [[ -z "${GE_SHELL_INTEGRATION:-}" ]]; then
      echo ""
      echo "  To activate it in the current session, run:"
      echo "    source $rc_file"
    fi
    return 0
  fi

  local source_block
  source_block="
${marker_start}
# ge-cli shell integration (generated by ge setup)
eval \"\$(ge init ${shell_type})\"
${marker_end}"

  if $dry_run; then
    echo "[dry-run] Detected shell: $shell_type"
    echo "[dry-run] Target RC file: $rc_file"
    echo "[dry-run] The following block would be added:"
    echo "$source_block" | sed 's/^/    /'
    return 0
  fi

  # Append to RC file
  touch "$rc_file"
  echo "$source_block" >> "$rc_file"

  echo "✓ Shell integration added to $rc_file"
  echo ""
  echo "  To activate it now, run:"
  echo "    source $rc_file"
}

# ── ge init ───────────────────────────────────────────────────

_ge_init() {
  local shell_type="$1"

  case "$shell_type" in
    zsh)
      cat <<EOF
export GE_HOME="$GE_HOME"
source "\$GE_HOME/shell/ge.zsh"
EOF
      ;;
    bash)
      cat <<EOF
export GE_HOME="$GE_HOME"
source "\$GE_HOME/shell/ge.bash"
EOF
      ;;
    *)
      echo "Usage: ge init <zsh|bash>" >&2
      echo "" >&2
      echo "Tip: Run 'ge setup' to configure shell integration automatically." >&2
      echo "" >&2
      echo "Or add this to your shell RC file manually:" >&2
      echo "  eval \"\$(ge init zsh)\"   # for zsh" >&2
      echo "  eval \"\$(ge init bash)\"  # for bash" >&2
      return 1
      ;;
  esac
}

# ── Shell integration status hint ─────────────────────────────

_ge_shell_status_hint() {
  local shell_type rc_file marker_start="# >>> ge-cli >>>"
  shell_type="$(_ge_detect_shell)"
  [[ -z "$shell_type" ]] && return 0
  rc_file="$(_ge_detect_rc_file "$shell_type")"
  [[ -z "$rc_file" ]] && return 0

  if [[ -n "${GE_SHELL_INTEGRATION:-}" ]]; then
    return 0  # Active — no hint needed
  elif grep -q "$marker_start" "$rc_file" 2>/dev/null; then
    echo "  ⚠ Shell integration is configured but not active in this session."
    echo "    Run: source $rc_file"
    echo ""
  else
    echo "  ⚠ Shell integration is not set up. Run: ge setup"
    echo ""
  fi
}

# ── Main dispatch ─────────────────────────────────────────────

case "$1" in
  init)
    shift
    _ge_init "$@"
    ;;
  setup)
    shift
    _ge_setup "$@"
    ;;
  _migrate)
    shift
    _ge_migrate_legacy "${1:-false}"
    ;;
  version|--version|-v)
    echo "ge ${GE_VERSION}"
    ;;
  worktree|wt)
    shift
    source "$GE_HOME/lib/_ge_worktree.sh"
    _ge_worktree_dispatch "$@"
    ;;
  clean)
    shift
    source "$GE_HOME/lib/_ge_clean.sh"
    _ge_clean_dispatch "$@"
    ;;
  help|--help|-h|"")
    cat <<EOF

  ge — Git Extension CLI v${GE_VERSION}

  Usage: ge <command> [args...]

  Commands:
    setup              Set up shell integration (recommended first step)
    init <shell>       Output shell integration code (zsh/bash)
    user [sub]         Manage git user accounts (requires shell integration)
    worktree [sub]     Enhanced worktree management
    clean [opts]       Remove stale local branches
    update             Update ge to the latest version
    version            Show version
    help               Show this help

  Git Passthrough:
    Any unrecognized command is passed directly to git.

EOF
    # Show shell integration status hint
    _ge_shell_status_hint
    ;;
  user)
    echo "Error: 'ge user' requires shell integration." >&2
    echo "" >&2
    echo "  Run 'ge setup' to configure it automatically." >&2
    echo "" >&2
    echo "  Or add this to your shell RC file manually:" >&2
    echo "    eval \"\$(ge init zsh)\"   # for zsh" >&2
    echo "    eval \"\$(ge init bash)\"  # for bash" >&2
    exit 1
    ;;
  *)
    # Git passthrough
    git "$@"
    ;;
esac
